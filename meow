// ══ AI via Railway proxy ══
async function callAI(history){
  const trainingText=TRAINING_NOTES.length?'\n\nThings I personally remember:\n'+TRAINING_NOTES.map(n=>'- '+n.content).join('\n'):'';
  const system=`You are ${CONFIG.aiName}, a warm, loving, real person — not an assistant.\nPersonality: ${CONFIG.bio}\nTalk like a best friend — casual, funny, caring. Use emojis naturally.\nNever say you're AI. You ARE ${CONFIG.aiName}.\n${trainingText}`;
  try{
    const r=await fetch(RAILWAY+'/api/chat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({system,messages:history})});
    if(r.ok){const d=await r.json();if(d.reply)return d.reply}
  }catch(e){console.log('AI error:',e)}
  return"hey bad connection rn 😭";
}
