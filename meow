<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>her space — owner 💗</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Nunito:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--rose:#f2687a;--rose-soft:#f9a8b4;--cream:#fff8f3;--blush:#fde8e8;--lilac:#e8d5f5;--lilac-mid:#c9a7e8;--plum:#9b5fbf;--warm-dark:#3a1a2e;--warm-mid:#6b3a52;--text-soft:#7a4a60;--white:#ffffff;--shadow:0 8px 32px rgba(155,95,191,0.13);--shadow-lg:0 20px 60px rgba(155,95,191,0.2)}
html,body{height:100%;font-family:'Nunito',sans-serif;background:var(--cream);color:var(--warm-dark);overflow-x:hidden}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:var(--blush)}::-webkit-scrollbar-thumb{background:var(--rose-soft);border-radius:10px}
@keyframes fadeUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)}}
@keyframes heartbeat{0%,100%{transform:scale(1)}14%{transform:scale(1.18)}28%{transform:scale(1)}42%{transform:scale(1.1)}70%{transform:scale(1)}}
@keyframes pulseGlow{0%,100%{box-shadow:0 0 0 0 rgba(242,104,122,0.45)}50%{box-shadow:0 0 0 14px rgba(242,104,122,0)}}
@keyframes dots{0%,80%,100%{transform:scale(0);opacity:.3}40%{transform:scale(1);opacity:1}}
@keyframes popIn{0%{opacity:0;transform:scale(0.82) translateY(10px)}65%{transform:scale(1.03)}100%{opacity:1;transform:scale(1) translateY(0)}}
@keyframes slideIn{from{opacity:0;transform:translateX(-18px)}to{opacity:1;transform:translateX(0)}}
.heartbeat{animation:heartbeat 2.8s ease-in-out infinite}
.btn-primary{padding:15px 24px;border-radius:16px;border:none;cursor:pointer;background:linear-gradient(135deg,var(--rose),var(--plum));color:#fff;font-family:'Nunito',sans-serif;font-size:16px;font-weight:800;box-shadow:0 8px 24px rgba(242,104,122,0.32);transition:transform .2s,box-shadow .2s}
.btn-primary:hover{transform:translateY(-2px) scale(1.02)}.btn-primary:active{transform:scale(0.97)}
.btn-ghost{padding:12px 20px;border-radius:14px;border:2px solid var(--lilac);background:transparent;color:var(--warm-mid);font-family:'Nunito',sans-serif;font-size:15px;font-weight:700;cursor:pointer;transition:all .2s}
.btn-ghost:hover{background:var(--blush);border-color:var(--rose-soft)}
.inp{width:100%;padding:14px 18px;border-radius:14px;border:2px solid var(--lilac);outline:none;font-size:16px;font-family:'Nunito',sans-serif;background:var(--cream);color:var(--warm-dark);transition:border-color .2s}
.inp:focus{border-color:var(--rose)}.inp::placeholder{color:var(--rose-soft)}
.tab-btn{padding:10px 18px;border-radius:12px;border:none;cursor:pointer;font-family:'Nunito',sans-serif;font-size:14px;font-weight:700;background:var(--blush);color:var(--text-soft);transition:all .2s;white-space:nowrap}
.tab-btn.active{background:linear-gradient(135deg,var(--rose),var(--plum));color:#fff;box-shadow:0 4px 14px rgba(242,104,122,0.3)}
.card{background:rgba(255,255,255,0.88);border-radius:20px;border:1px solid rgba(232,213,245,0.5);box-shadow:var(--shadow);transition:transform .2s,box-shadow .2s}
.card:hover{transform:translateY(-3px);box-shadow:var(--shadow-lg)}
.bubble-wrap{display:flex;margin-bottom:14px}.bubble-wrap.mine{justify-content:flex-end}.bubble-wrap.theirs{justify-content:flex-start}
.bubble-avatar{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--rose),var(--lilac-mid));display:flex;align-items:center;justify-content:center;font-size:14px;margin-right:8px;flex-shrink:0;align-self:flex-end}
.bubble{max-width:72%;padding:10px 16px;font-size:14px;line-height:1.6;font-weight:500}
.bubble.mine{border-radius:22px 22px 6px 22px;background:linear-gradient(135deg,var(--rose),var(--plum));color:#fff}
.bubble.theirs{border-radius:22px 22px 22px 6px;background:var(--white);color:var(--warm-dark);box-shadow:var(--shadow);border:1px solid rgba(232,213,245,0.55)}
.bubble-name{font-size:10px;color:var(--lilac-mid);font-weight:800;margin-bottom:3px;letter-spacing:.8px;text-transform:uppercase}
.typing-dots{display:flex;gap:5px;align-items:center;padding:12px 16px}
.typing-dots span{width:7px;height:7px;border-radius:50%;background:var(--rose-soft);animation:dots 1.2s ease-in-out infinite}
.typing-dots span:nth-child(2){animation-delay:.2s}.typing-dots span:nth-child(3){animation-delay:.4s}
#auth-guard{position:fixed;inset:0;z-index:9999;background:linear-gradient(145deg,#fff0f5,#fde8f0,#ede0ff,#fff5fb);display:flex;align-items:center;justify-content:center;padding:24px}
#auth-guard-card{background:rgba(255,255,255,0.92);backdrop-filter:blur(28px);border-radius:28px;padding:44px 36px;max-width:380px;width:100%;box-shadow:0 28px 80px rgba(155,95,191,0.22);animation:fadeUp .6s ease;text-align:center}
</style>
</head>
<body style="background:linear-gradient(145deg,#fff0f5,#fde8f0,#ede0ff,#fff5fb);min-height:100vh">

<div id="auth-guard">
  <div id="auth-guard-card">
    <div class="heartbeat" style="font-size:56px;margin-bottom:16px">🔐</div>
    <h2 style="font-family:'Playfair Display',serif;font-size:28px;color:var(--warm-dark);margin-bottom:8px">owner access only</h2>
    <p style="color:var(--text-soft);font-size:15px;margin-bottom:28px">enter your owner password 💗</p>
    <input class="inp" type="password" id="guard-password" placeholder="password 🔒" style="text-align:center;margin-bottom:14px" onkeydown="if(event.key==='Enter')guardLogin()"/>
    <button class="btn-primary" onclick="guardLogin()" style="width:100%;margin-bottom:14px">enter 🌸</button>
    <div id="guard-err" style="color:var(--rose);font-size:14px;font-weight:700;display:none">wrong password babe 😅</div>
    <button onclick="window.location.href='platform.html'" style="background:none;border:none;color:var(--text-soft);font-size:14px;cursor:pointer;margin-top:10px;font-family:'Nunito',sans-serif">← back</button>
  </div>
</div>

<div id="owner-dashboard" style="display:none;flex-direction:column;min-height:100vh">

  <div style="padding:18px 26px;display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,0.85);backdrop-filter:blur(22px);border-bottom:1px solid rgba(232,213,245,0.5);position:sticky;top:0;z-index:100">
    <div id="owner-greeting" style="font-family:'Playfair Display',serif;font-size:22px;font-weight:700;color:var(--warm-dark)">🌸 your space</div>
    <div style="display:flex;gap:10px">
      <a href="platform.html" class="btn-ghost" style="padding:8px 16px;font-size:13px;text-decoration:none">← platform</a>
      <button class="btn-ghost" onclick="ownerLogout()" style="padding:8px 16px;font-size:13px">sign out</button>
    </div>
  </div>

  <div style="display:flex;gap:8px;padding:14px 22px;background:rgba(255,255,255,0.65);border-bottom:1px solid rgba(232,213,245,0.4);overflow-x:auto;flex-shrink:0">
    <button class="tab-btn active" onclick="ownerTab('home',this)">🏠 home</button>
    <button class="tab-btn" onclick="ownerTab('customize',this)">✏️ customise</button>
    <button class="tab-btn" onclick="ownerTab('training',this)">🧠 train</button>
    <button class="tab-btn" onclick="ownerTab('convos',this)">💬 convos</button>
    <button class="tab-btn" onclick="ownerTab('takeover',this)">🎭 takeover</button>
  </div>

  <div style="flex:1;overflow-y:auto;padding:28px 22px;max-width:640px;margin:0 auto;width:100%">

    <!-- HOME -->
    <div id="otab-home" style="animation:fadeUp .6s ease">
      <h2 style="font-family:'Playfair Display',serif;font-size:30px;color:var(--warm-dark);margin-bottom:8px">welcome back 💗</h2>
      <p style="color:var(--text-soft);font-size:16px;margin-bottom:24px">manage your space from here</p>
      <div id="stats-bar" style="background:rgba(255,255,255,0.88);border-radius:16px;padding:16px 20px;margin-bottom:24px;border:1px solid rgba(232,213,245,0.5);display:flex;gap:24px">
        <div style="text-align:center"><div id="stat-users" style="font-size:28px;font-weight:900;color:var(--rose)">—</div><div style="font-size:12px;color:var(--text-soft);font-weight:700">users</div></div>
        <div style="text-align:center"><div id="stat-msgs" style="font-size:28px;font-weight:900;color:var(--plum)">—</div><div style="font-size:12px;color:var(--text-soft);font-weight:700">messages</div></div>
        <div style="text-align:center"><div id="stat-notes" style="font-size:28px;font-weight:900;color:var(--lilac-mid)">—</div><div style="font-size:12px;color:var(--text-soft);font-weight:700">training notes</div></div>
      </div>
      <div id="home-cards"></div>
    </div>

    <!-- CUSTOMIZE -->
    <div id="otab-customize" style="display:none;animation:fadeUp .6s ease">
      <h2 style="font-family:'Playfair Display',serif;font-size:26px;color:var(--warm-dark);margin-bottom:24px">✏️ customise</h2>
      <div id="customize-fields"></div>
      <div style="margin-bottom:22px">
        <label style="font-size:12px;font-weight:800;color:var(--text-soft);display:block;margin-bottom:7px;text-transform:uppercase;letter-spacing:1px">custom image link 🖼️</label>
        <input class="inp" id="field-customImg" placeholder="https://your-image-url.com/photo.jpg"/>
      </div>
      <div style="margin-bottom:22px;padding:20px;background:rgba(155,95,191,0.07);border-radius:16px;border:1px solid rgba(232,213,245,0.6)">
        <label style="font-size:12px;font-weight:800;color:var(--text-soft);display:block;margin-bottom:7px;text-transform:uppercase;letter-spacing:1px">change password 🔐</label>
        <input class="inp" type="password" id="field-new-pass" placeholder="new password..." style="margin-bottom:10px"/>
        <input class="inp" type="password" id="field-confirm-pass" placeholder="confirm..."/>
        <p id="pass-msg" style="font-size:13px;margin-top:8px;display:none"></p>
      </div>
      <button class="btn-primary" onclick="saveConfig()" style="width:100%" id="save-btn">save changes ✨</button>
    </div>

    <!-- TRAINING -->
    <div id="otab-training" style="display:none;animation:fadeUp .6s ease">
      <h2 style="font-family:'Playfair Display',serif;font-size:26px;color:var(--warm-dark);margin-bottom:8px">🧠 train manually</h2>
      <p style="color:var(--text-soft);font-size:14px;margin-bottom:6px">these notes are stored in MongoDB and injected into every conversation 💗</p>
      <div style="display:flex;gap:8px;margin-bottom:22px;margin-top:18px">
        <button class="tab-btn active" id="train-mode-notes" onclick="trainMode('notes',this)" style="flex:1">📝 notes</button>
        <button class="tab-btn" id="train-mode-chat" onclick="trainMode('chat',this)" style="flex:1">💬 chat train</button>
      </div>

      <div id="train-notes-panel">
        <div style="display:flex;gap:10px;margin-bottom:18px">
          <input class="inp" id="note-input" placeholder='e.g. "I always say omg when surprised"' onkeydown="if(event.key==='Enter')addNote()" style="flex:1"/>
          <button class="btn-primary" onclick="addNote()" style="padding:14px 20px">add</button>
        </div>
        <div id="notes-list"></div>
      </div>

      <div id="train-chat-panel" style="display:none">
        <div style="background:rgba(255,255,255,0.75);border-radius:20px;border:1px solid rgba(232,213,245,0.5);box-shadow:var(--shadow);overflow:hidden">
          <div style="padding:10px 16px;background:var(--blush);border-bottom:1px solid rgba(232,213,245,0.4)">
            <span style="font-size:13px;color:var(--text-soft);font-weight:700">💡 exchanges here auto-save as training notes to MongoDB</span>
          </div>
          <div id="train-chat-messages" style="height:280px;overflow-y:auto;padding:14px"></div>
          <div id="train-typing" style="display:none;padding:8px 16px;align-items:flex-end;gap:8px">
            <div style="width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,var(--rose),var(--lilac-mid));display:flex;align-items:center;justify-content:center;font-size:13px" id="train-typing-avatar">🌸</div>
            <div style="background:var(--white);border-radius:16px 16px 16px 4px;box-shadow:var(--shadow)"><div class="typing-dots"><span></span><span></span><span></span></div></div>
          </div>
          <div style="padding:12px 14px;border-top:1px solid rgba(232,213,245,0.4);display:flex;gap:10px">
            <input class="inp" id="train-input" placeholder="chat to train... 💗" onkeydown="if(event.key==='Enter')sendTrainMsg()" style="flex:1;padding:11px 14px;font-size:14px"/>
            <button onclick="sendTrainMsg()" style="padding:11px 15px;border-radius:14px;border:none;background:linear-gradient(135deg,var(--rose),var(--plum));color:#fff;font-size:18px;cursor:pointer">💌</button>
          </div>
        </div>
      </div>
    </div>

    <!-- CONVOS (Cloudflare D1 reader) -->
    <div id="otab-convos" style="display:none;animation:fadeUp .6s ease">
      <h2 style="font-family:'Playfair Display',serif;font-size:26px;color:var(--warm-dark);margin-bottom:8px">💬 all conversations</h2>
      <p style="color:var(--text-soft);font-size:14px;margin-bottom:20px">live from Cloudflare D1 — all user chats 🌐</p>
      <div style="display:flex;gap:10px;margin-bottom:18px">
        <button class="btn-primary" onclick="loadAllConvos()" style="flex:1;padding:12px">load convos 🔄</button>
        <button onclick="makeNotesFromConvos()" style="flex:1;padding:12px;border-radius:14px;border:2px solid var(--lilac);background:transparent;color:var(--warm-mid);font-family:'Nunito',sans-serif;font-size:14px;font-weight:700;cursor:pointer">🧠 extract training</button>
      </div>
      <div id="convos-list" style="color:var(--text-soft);font-size:14px;text-align:center;padding:32px 0">tap "load convos" to fetch from Cloudflare 🌸</div>
    </div>

    <!-- TAKEOVER -->
    <div id="otab-takeover" style="display:none;animation:fadeUp .6s ease">
      <h2 style="font-family:'Playfair Display',serif;font-size:26px;color:var(--warm-dark);margin-bottom:8px">🎭 take over</h2>
      <p style="color:var(--text-soft);font-size:15px;margin-bottom:28px">jump in as yourself — they won't know 😂💗</p>
      <div id="takeover-card" class="card" style="padding:24px;margin-bottom:22px;transition:all .3s">
        <div style="display:flex;align-items:center;justify-content:space-between">
          <div>
            <div style="font-weight:800;font-size:18px;color:var(--warm-dark)" id="takeover-title">take over mode</div>
            <div style="font-size:13px;color:var(--text-soft);margin-top:3px" id="takeover-sub">tap to jump in</div>
          </div>
          <button id="takeover-btn" class="btn-primary" onclick="toggleTakeover()" style="padding:12px 22px;font-size:14px">take over 🎭</button>
        </div>
        <div id="takeover-panel" style="display:none;margin-top:20px;animation:fadeUp .4s ease">
          <div id="takeover-msgs" style="background:rgba(255,255,255,0.6);border-radius:14px;padding:14px;margin-bottom:12px;min-height:60px;max-height:130px;overflow-y:auto">
            <p style="color:var(--text-soft);font-size:14px" id="takeover-placeholder">your messages will show here 💗</p>
          </div>
          <div style="display:flex;gap:10px">
            <input class="inp" id="takeover-input" placeholder="type as yourself..." onkeydown="if(event.key==='Enter')sendOwnerMsg()" style="flex:1"/>
            <button onclick="sendOwnerMsg()" style="padding:12px 15px;border-radius:14px;border:none;background:var(--rose);color:#fff;font-size:18px;cursor:pointer">💌</button>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
// ══ ENDPOINTS ══
const RAILWAY='https://YOUR-APP.railway.app';
const CF='https://YOUR-WORKER.workers.dev';

const DEFAULT_CONFIG={ownerName:'Sofia',aiName:'Sofi',welcomeMsg:"hey love, so glad you're here 🌸",bio:'your safe space to talk, laugh & feel understood 💗',bannerEmoji:'🌸',customImg:'',ownerPasswordHash:''};
let CONFIG={...DEFAULT_CONFIG},TRAINING_NOTES=[],OWNER_TOOK_OVER=false,TRAIN_MSGS=[];

// ══ API ══
async function rGet(p){try{const r=await fetch(RAILWAY+p);return await r.json()}catch{return null}}
async function rPost(p,d){try{const r=await fetch(RAILWAY+p,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(d)});return await r.json()}catch{return null}}
async function cfGet(p){try{const r=await fetch(CF+p);return await r.json()}catch{return null}}

async function loadConfig(){const cfg=await rGet('/api/config');if(cfg){CONFIG={...DEFAULT_CONFIG,...cfg};localStorage.setItem('pg_config',JSON.stringify(CONFIG))}else CONFIG={...DEFAULT_CONFIG,...JSON.parse(localStorage.getItem('pg_config')||'{}')} }
async function loadTraining(){const n=await rGet('/api/training');TRAINING_NOTES=Array.isArray(n)?n:JSON.parse(localStorage.getItem('pg_training')||'[]')}
async function saveTraining(){localStorage.setItem('pg_training',JSON.stringify(TRAINING_NOTES));rPost('/api/training',{notes:TRAINING_NOTES})}
async function saveConfigToDB(){localStorage.setItem('pg_config',JSON.stringify(CONFIG));await rPost('/api/config',CONFIG)}

// ══ HASH ══
async function hashPass(pw){const buf=await crypto.subtle.digest('SHA-256',new TextEncoder().encode(pw));return Array.from(new Uint8Array(buf)).map(b=>b.toString(16).padStart(2,'0')).join('')}

// ══ AUTH ══
async function guardLogin(){
  const pw=document.getElementById('guard-password').value;if(!pw)return;
  const hash=await hashPass(pw);await loadConfig();
  const stored=CONFIG.ownerPasswordHash||'';
  if(!stored){CONFIG.ownerPasswordHash=hash;await saveConfigToDB();grantAccess();return}
  if(hash===stored)grantAccess();
  else{document.getElementById('guard-err').style.display='block';document.getElementById('guard-password').value=''}
}
function grantAccess(){
  localStorage.setItem('pg_session',JSON.stringify({id:'owner',name:CONFIG.ownerName,isOwner:true}));
  document.getElementById('auth-guard').style.display='none';
  document.getElementById('owner-dashboard').style.display='flex';
  initDashboard();
}
(async function checkSession(){
  const s=localStorage.getItem('pg_session');
  if(s){try{const u=JSON.parse(s);if(u.isOwner){document.getElementById('auth-guard').style.display='none';document.getElementById('owner-dashboard').style.display='flex';await initDashboard();return}}catch{}}
})();
function ownerLogout(){localStorage.removeItem('pg_session');window.location.href='platform.html'}

async function initDashboard(){
  await loadConfig();await loadTraining();
  document.getElementById('owner-greeting').textContent=CONFIG.bannerEmoji+' your space, '+CONFIG.ownerName;
  buildHomeCards();buildCustomizeFields();renderNotes();updateTakeoverHowto();
  ownerTab('home',document.querySelector('.tab-btn'));
  loadStats();
}

// ══ STATS from Cloudflare ══
async function loadStats(){
  const s=await cfGet('/api/stats');
  if(s){document.getElementById('stat-users').textContent=s.users||0;document.getElementById('stat-msgs').textContent=s.messages||0}
  document.getElementById('stat-notes').textContent=TRAINING_NOTES.length;
}

// ══ TABS ══
function ownerTab(name,btn){['home','customize','training','convos','takeover'].forEach(t=>document.getElementById('otab-'+t).style.display=t===name?'block':'none');document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));if(btn)btn.classList.add('active')}

// ══ HOME CARDS ══
function buildHomeCards(){
  const cards=[{icon:'✏️',title:'customise',desc:'name, bio, emoji, theme',tab:'customize'},{icon:'🧠',title:'manual training',desc:'MongoDB — notes & chat training',tab:'training'},{icon:'💬',title:'all convos',desc:'Cloudflare D1 — live chats',tab:'convos'},{icon:'🎭',title:'take over',desc:'jump in as yourself',tab:'takeover'}];
  document.getElementById('home-cards').innerHTML=cards.map((c,i)=>`<div class="card" style="padding:18px 22px;margin-bottom:12px;cursor:pointer;display:flex;align-items:center;gap:14px;animation:fadeUp .5s ease ${i*.08}s both" onclick="ownerTab('${c.tab}',document.querySelectorAll('.tab-btn')[${i+1}])"><div style="font-size:34px">${c.icon}</div><div><div style="font-weight:800;font-size:16px;color:var(--warm-dark);margin-bottom:2px">${c.title}</div><div style="color:var(--text-soft);font-size:13px">${c.desc}</div></div><div style="margin-left:auto;color:var(--rose-soft);font-size:18px">→</div></div>`).join('');
}

// ══ CUSTOMIZE ══
const CFIELDS=[{label:'your name',key:'ownerName',placeholder:'Sofia'},{label:"personality name",key:'aiName',placeholder:'Sofi'},{label:'welcome message',key:'welcomeMsg',placeholder:"hey love 🌸"},{label:'bio',key:'bio',placeholder:'your safe space 💗'},{label:'instagram handle',key:'igHandle',placeholder:'yourhandle'},{label:'banner emoji',key:'bannerEmoji',placeholder:'🌸'}];
function buildCustomizeFields(){
  document.getElementById('customize-fields').innerHTML=CFIELDS.map(f=>`<div style="margin-bottom:18px"><label style="font-size:12px;font-weight:800;color:var(--text-soft);display:block;margin-bottom:7px;text-transform:uppercase;letter-spacing:1px">${f.label}</label><input class="inp" id="field-${f.key}" value="${CONFIG[f.key]||''}" placeholder="${f.placeholder}"/></div>`).join('');
  document.getElementById('field-customImg').value=CONFIG.customImg||'';
}
async function saveConfig(){
  CFIELDS.forEach(f=>{const el=document.getElementById('field-'+f.key);if(el)CONFIG[f.key]=el.value.trim()});
  const ci=document.getElementById('field-customImg');if(ci)CONFIG.customImg=ci.value.trim();
  const np=document.getElementById('field-new-pass').value,cp=document.getElementById('field-confirm-pass').value,pmsg=document.getElementById('pass-msg');
  if(np||cp){
    if(np!==cp){pmsg.style.display='block';pmsg.style.color='var(--rose)';pmsg.textContent="passwords don't match 😅";return}
    if(np.length<4){pmsg.style.display='block';pmsg.style.color='var(--rose)';pmsg.textContent="min 4 chars babe 💗";return}
    CONFIG.ownerPasswordHash=await hashPass(np);
    pmsg.style.display='block';pmsg.style.color='var(--plum)';pmsg.textContent="password updated! 🔐";
    document.getElementById('field-new-pass').value='';document.getElementById('field-confirm-pass').value='';
    setTimeout(()=>{pmsg.style.display='none'},2500);
  }
  await saveConfigToDB();
  const btn=document.getElementById('save-btn');btn.textContent='saved! 💗';btn.style.background='var(--plum)';
  setTimeout(()=>{btn.textContent='save changes ✨';btn.style.background=''},2000);
  document.getElementById('owner-greeting').textContent=CONFIG.bannerEmoji+' your space, '+CONFIG.ownerName;
}

// ══ TRAINING NOTES (MongoDB) ══
function trainMode(mode,btn){document.getElementById('train-notes-panel').style.display=mode==='notes'?'block':'none';document.getElementById('train-chat-panel').style.display=mode==='chat'?'block':'none';document.querySelectorAll('[id^="train-mode"]').forEach(b=>b.classList.remove('active'));btn.classList.add('active')}
function renderNotes(){
  const el=document.getElementById('notes-list');if(!el)return;
  if(!TRAINING_NOTES.length){el.innerHTML='<p style="color:var(--text-soft);font-size:14px;text-align:center;padding:28px 0">no notes yet 🌸</p>';return}
  el.innerHTML=TRAINING_NOTES.map((n,i)=>`<div style="background:rgba(255,255,255,0.88);border-radius:12px;padding:12px 16px;margin-bottom:9px;display:flex;align-items:center;gap:10px;border:1px solid rgba(232,213,245,0.5);animation:slideIn .3s ease"><div style="flex:1;font-size:14px;color:var(--warm-dark);font-weight:500">${n.content}</div><button onclick="removeNote(${i})" style="background:none;border:none;color:var(--rose-soft);font-size:18px;cursor:pointer;flex-shrink:0">×</button></div>`).join('');
  document.getElementById('stat-notes').textContent=TRAINING_NOTES.length;
}
async function addNote(){const inp=document.getElementById('note-input'),val=inp.value.trim();if(!val)return;TRAINING_NOTES.push({content:val,ts:Date.now()});await saveTraining();inp.value='';renderNotes()}
async function removeNote(i){TRAINING_NOTES.splice(i,1);await saveTraining();renderNotes()}

// ══ CHAT TRAINING ══
function renderTrainBubble(msg,animate=false){
  const el=document.getElementById('train-chat-messages');
  const wrap=document.createElement('div');wrap.className='bubble-wrap '+(msg.role==='user'?'mine':'theirs');
  if(animate)wrap.style.animation='popIn .3s ease forwards';
  if(msg.role==='assistant'){const av=document.createElement('div');av.className='bubble-avatar';av.textContent=CONFIG.bannerEmoji;wrap.appendChild(av)}
  const bub=document.createElement('div');bub.className='bubble '+(msg.role==='user'?'mine':'theirs');
  if(msg.role==='assistant'){const nm=document.createElement('div');nm.className='bubble-name';nm.textContent=CONFIG.aiName;bub.appendChild(nm)}
  const t=document.createElement('div');t.textContent=msg.content;bub.appendChild(t);wrap.appendChild(bub);el.appendChild(wrap);el.scrollTop=el.scrollHeight;
}
async function sendTrainMsg(){
  const inp=document.getElementById('train-input'),txt=inp.value.trim();if(!txt)return;inp.value='';
  const userMsg={role:'user',content:txt};TRAIN_MSGS.push(userMsg);renderTrainBubble(userMsg,true);
  document.getElementById('train-typing-avatar').textContent=CONFIG.bannerEmoji;
  document.getElementById('train-typing').style.display='flex';
  setTimeout(async()=>{
    document.getElementById('train-typing').style.display='none';
    const reply=await callAI(TRAIN_MSGS.map(m=>({role:m.role,content:m.content})));
    const aiMsg={role:'assistant',content:reply};TRAIN_MSGS.push(aiMsg);renderTrainBubble(aiMsg,true);
    // auto save as training note to MongoDB
    TRAINING_NOTES.push({content:`When asked "${txt}", reply like: "${reply}"`,ts:Date.now()});
    await saveTraining();renderNotes();
  },700+Math.random()*900);
}

// ══ ALL CONVOS from Cloudflare D1 ══
async function loadAllConvos(){
  const el=document.getElementById('convos-list');el.innerHTML='<p style="color:var(--text-soft);font-size:14px;text-align:center;padding:20px">loading from Cloudflare... 🌐</p>';
  const data=await cfGet('/api/all-convos?limit=300');
  if(!data||!data.length){el.innerHTML='<p style="color:var(--text-soft);font-size:14px;text-align:center;padding:20px">no conversations yet 🌸</p>';return}

  // Group by user
  const grouped={};
  data.forEach(m=>{if(!grouped[m.user_id])grouped[m.user_id]=[];grouped[m.user_id].push(m)});

  el.innerHTML=Object.entries(grouped).map(([uid,msgs])=>`
    <div style="background:rgba(255,255,255,0.88);border-radius:14px;margin-bottom:14px;border:1px solid rgba(232,213,245,0.5);overflow:hidden">
      <div style="padding:10px 16px;background:var(--blush);display:flex;align-items:center;justify-content:space-between">
        <span style="font-weight:800;font-size:14px;color:var(--warm-dark)">@${uid.replace('ig_','').replace('manual_','')}</span>
        <span style="font-size:12px;color:var(--text-soft)">${msgs.length} messages</span>
      </div>
      <div style="padding:12px 14px;max-height:180px;overflow-y:auto">
        ${msgs.slice(-8).map(m=>`<div style="margin-bottom:6px;font-size:13px;color:${m.role==='user'?'var(--warm-dark)':'var(--plum)'}"><span style="font-weight:800;margin-right:6px">${m.role==='user'?'them':'ai'}:</span>${m.content}</div>`).join('')}
      </div>
    </div>`).join('');
}

// Extract training notes from all conversations
async function makeNotesFromConvos(){
  const data=await cfGet('/api/all-convos?limit=200');
  if(!data||!data.length)return alert('no convos to extract from 🌸');
  // Pair up user+assistant messages and add as training notes
  let added=0;
  for(let i=0;i<data.length-1;i++){
    if(data[i].role==='user'&&data[i+1].role==='assistant'){
      const note=`When asked "${data[i].content.slice(0,80)}", reply like: "${data[i+1].content.slice(0,120)}"`;
      const exists=TRAINING_NOTES.some(n=>n.content===note);
      if(!exists){TRAINING_NOTES.push({content:note,ts:Date.now()});added++;}
    }
  }
  await saveTraining();renderNotes();
  alert(`extracted ${added} new training notes from conversations 🧠💗`);
}

